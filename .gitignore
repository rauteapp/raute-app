# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# sensitive environment variable reference
ENV_VARIABLES_REFERENCE.md

# test scripts with credentials
test_login.ps1
*.ps1

# archive and cleanup
/archive
temp_remote.txt
*.zip

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Google Services (contains API keys)
ios/App/GoogleService-Info.plist
android/app/google-services.json
