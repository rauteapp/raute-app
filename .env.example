# ============================================
# Raute App — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# === PUBLIC (exposed to browser — safe to share) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_APP_URL=https://raute.io

# === SERVER-SIDE ONLY (never exposed to browser) ===

# Supabase service role key (full database access, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Maps Geocoding API key (server-side proxy at /api/geocode)
GOOGLE_MAPS_API_KEY=your_google_maps_key

# xAI/Grok API key (server-side proxy at /api/ai/*)
XAI_API_KEY=your_xai_api_key

# Firebase Cloud Messaging (push notifications)
FIREBASE_PROJECT_ID=raute-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@raute-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# Resend (transactional email)
RESEND_API_KEY=your_resend_api_key

# Stripe (subscriptions & payments)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_PIONEER_MONTHLY=price_xxx
STRIPE_PRICE_PIONEER_ANNUAL=price_xxx
STRIPE_FOUNDING_COUPON_ID=your_coupon_id

# RevenueCat (iOS in-app purchases)
NEXT_PUBLIC_REVENUECAT_API_KEY_IOS=your_revenuecat_ios_key
REVENUECAT_WEBHOOK_AUTH_TOKEN=your_webhook_token
